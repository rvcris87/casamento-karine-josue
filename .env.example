# Variáveis de ambiente - EXEMPLO
# Copie este arquivo para .env e preencha com seus valores reais

# ============================================================================
# BANCO DE DADOS - SUPABASE
# ============================================================================
# Use a URL do POOLER do Supabase (modo session ou transaction)
# Formato: postgresql://user.role:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ============================================================================
# SEGURANÇA FLASK
# ============================================================================
# Gere uma chave secreta segura com: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=

# ============================================================================
# MERCADO PAGO - INTEGRAÇÃO DE PAGAMENTOS
# ============================================================================
# Credenciais modo TESTE (substitua pelos valores de produção quando necessário)
# Obtenha em: https://www.mercadopago.com.br/developers/pt-BR/docs

# Access Token - Para autenticação nas requisições de API
# TESTE: APP_USR-7108049560326594-042212-ee879f6a87885115519a5fed61ab8c04-3352130635
MERCADO_PAGO_ACCESS_TOKEN=

# Public Key - Para integração no frontend (webhook e validações)
# TESTE: APP_USR-583c2032-5036-4f0f-a2f8-c6cef74d0347
MERCADO_PAGO_PUBLIC_KEY=

# ============================================================================
# CONFIGURAÇÃO DE AMBIENTE
# ============================================================================
# URL base da aplicação (para callbacks e webhooks do Mercado Pago)
# Exemplo local: http://localhost:5000
# Exemplo produção: https://seu-dominio.com
BASE_URL=http://localhost:5000

# Ambiente: development ou production
FLASK_ENV=development

# ============================================================================
# SENHAS E CREDENCIAIS SENSÍVEIS
# ============================================================================
# Admin login (se necessário)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ============================================================================
# INTEGRAÇÕES ADICIONAIS (OPCIONAL)
# ============================================================================
# SMTP para envio de emails
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Tokens de terceiros
# ... adicione conforme necessário
